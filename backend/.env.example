FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=replace-with-secure-key

JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-jira-email@example.com
JIRA_API_TOKEN=your-jira-api-token

CORS_ORIGINS=http://localhost:5173
EXPORT_DIR=exports

# Optional local GGUF model path for llama-cpp-python
LLM_PROVIDER=auto
LLM_MODEL_PATH=
LLM_N_CTX=4096
LLM_MAX_TOKENS=1200
LLM_TEMPERATURE=0.1
LLM_TIMEOUT_SECONDS=60

# Gemini (optional)
# Set LLM_PROVIDER=gemini to force Gemini usage
# Set LLM_PROVIDER=auto to prefer Gemini when key exists, otherwise fallback to llama/rule-based
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MINI_MODEL=gemini-2.0-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI (optional)
# Set LLM_PROVIDER=openai to force OpenAI usage
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MINI_MODEL=gpt-4.1-mini
OPENAI_NANO_MODEL=gpt-4.1-nano
OPENAI_4O_MINI_MODEL=gpt-4o-mini

# OpenRouter (optional)
# Set LLM_PROVIDER=openrouter to force OpenRouter usage
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Free-tier model allowlist is enforced in backend/services/llm.py

# UI default model shown in dropdown
LLM_DEFAULT_MODEL_ID=gemini-2.5-flash

# TestRail (optional: if empty, push API returns mock mode)
TESTRAIL_BASE_URL=
TESTRAIL_USERNAME=
TESTRAIL_API_KEY=
# Optional fallback if API key auth is disabled in TestRail instance
TESTRAIL_PASSWORD=
TESTRAIL_PROJECT_ID=
TESTRAIL_SUITE_ID=
TESTRAIL_SECTION_ID=

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
